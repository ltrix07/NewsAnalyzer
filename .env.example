DATABASE_URL=postgresql+asyncpg://news:news@localhost:5432/news_analyzer # Optional until DB code runs; required for engine DB access and Alembic.
OPENAI_API_KEY=your-openai-api-key # OpenAI API key used for both embeddings and chat completions.
PROFILE_NAME=volodymyr # Default user profile name loaded from config/profiles/<name>.yaml.
PROFILE_ROOT=config/profiles # Directory containing profile YAML files.
LOG_LEVEL=INFO # Application log verbosity.
APP_ENV=dev # Runtime environment, either dev or prod.
TELEGRAM_API_ID=123456 # Telegram MTProto API ID for channel ingestion.
TELEGRAM_API_HASH=your-telegram-api-hash # Telegram MTProto API hash paired with the API ID.
TELEGRAM_BOT_TOKEN=123456:telegram-bot-token # Telegram Bot API token for outbound digest delivery.
TELEGRAM_CHAT_ID=123456789 # Telegram chat id that receives outbound digests.
RAW_STORAGE_PATH=raw # Root directory for raw JSONL source output and per-source fetch state.
HTTP_TIMEOUT_SECONDS=30.0 # Default timeout in seconds for outbound source HTTP requests.
CLUSTER_SIMILARITY_THRESHOLD=0.82 # Minimum cosine similarity required to join an existing recent event.
CLUSTER_WINDOW_HOURS=36 # Only events seen within this many hours are candidates for new article assignment.
OPENAI_MODEL_RELEVANCE=gpt-4o-mini # OpenAI chat model used by the relevance stage.
OPENAI_MODEL_VERIFY=gpt-4o # OpenAI chat model used by the verify stage.
OPENAI_MODEL_SUMMARIZE=gpt-4o # OpenAI chat model used by the summarize stage.
TELEGRAM_LONG_POLL_SECONDS=25 # Long-poll timeout for python -m delivery.listener.
DISCUSSION_MODEL=gpt-4o-mini # OpenAI chat model used for Telegram digest discussion replies.
TAVILY_API_KEY=your-tavily-api-key # Tavily API key used for optional web research after digest discussions.
TAVILY_MAX_RESULTS=6 # Maximum Tavily search results used in one research answer.
TAVILY_SEARCH_DEPTH=advanced # Tavily search depth: basic or advanced.
RESEARCH_MODEL=gpt-4o # OpenAI chat model used to synthesize Tavily-backed research answers.
RESEARCH_DAILY_CAP=20 # Daily cap for post-discussion web research requests.
RESEARCH_PENDING_TTL_MINUTES=15 # Minutes a research button remains valid after it is offered.
POSTGRES_USER=news # PostgreSQL username used by docker compose.
POSTGRES_PASSWORD=news # PostgreSQL password used by docker compose.
POSTGRES_DB=news_analyzer # PostgreSQL database name used by docker compose.
